{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wine King",
  "version": "0.2.0",
  "identifier": "com.wineking.game",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "title": "Wine King",
        "width": 1600,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDMDVFOUJEMEJBNkQ0RgpSV1JQYmJyUW0xN0FCR1BGZEtaNUhwdjhYWG9JQWRVUm1yL3Y5YWYzSTg3c2ZadTIxb2dIK3RvZwo=",
      "endpoints": [
        "https://github.com/soundtrackgeek/wine_king/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
